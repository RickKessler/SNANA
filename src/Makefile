	$(CC) -o $@ $(SNLDFLAGS) \
		$(OBJ_SIM) \
		$(LCFITSIO) $(LGSL) \
		$(LPY) $(LROOT) -lm $(CPPLIB)
	cd $(OBJ); rm -f snlc_sim.o

$(BIN)/wfit.exe: $(OBJ)/wfit.o $(OBJ)/cnpy.o $(OBJ)/sntools.o \
	$(OBJ)/sntools_npz.o $(OBJ)/sntools_output.o $(OBJ)/sntools_cosmology.o
	$(MKDIR_P) $(BIN)
	$(CC) -o $@ $(SNLDFLAGS) \
		$(OBJ)/wfit.o \
		$(OBJ)/sntools.o \
		$(OBJ)/sntools_output.o \
		$(OBJ)/sntools_npz.o \
		$(OBJ)/cnpy.o \
		$(OBJ)/sntools_cosmology.o \
		$(LROOT) $(CPPLIB) \
		$(LCFITSIO) -lm $(LGSL) -lz
	cd $(OBJ); rm -f wfit.o

