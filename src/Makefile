# ===========================================================================
# OBJECT FILE RULES
# Each rule mirrors the original Makefile exactly:
#   (cd $(OBJ); compiler flags $(SRC)/file.c)
# This places the .o file in $(OBJ) naturally since the compiler
# writes output to the current directory when no -o is specified.
# ===========================================================================

